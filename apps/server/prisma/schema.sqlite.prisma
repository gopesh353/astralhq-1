generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PROJECT_LEAD
  QUALITY_REVIEWER
  TASKER
  ADMIN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  ON_LEAVE
  IDLE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectLifecycle {
  LIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum AllocationStatus {
  ALLOCATED
  UNALLOCATED
  PENDING
}

enum WorkItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  passwordHash      String
  role              UserRole       @default(TASKER)
  jobTitle          String?
  platform          String         @default("Multimango")
  qualityReviewerId String?
  reportingToId     String?
  avatar            String?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  refreshTokens     RefreshToken[]
  qualityReviewer   User?          @relation("ReviewerTaskers", fields: [qualityReviewerId], references: [id])
  taskers           User[]         @relation("ReviewerTaskers")
  reportingTo       User?          @relation("ReportingLine", fields: [reportingToId], references: [id])
  reports           User[]         @relation("ReportingLine")
  leaveRequests     LeaveRequest[]
  attendance        Attendance[]
  workItems         WorkItem[]
  allocations       ProjectAllocation[]
  notifications     Notification[]
  flagsCreated      ProjectFlag[]  @relation("FlagCreator")
  activities        Activity[]     @relation("ActivityActor")
  reviewsGiven      WorkItem[]     @relation("ReviewedBy")
  analytics         Analytics[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ipAddress String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id               String             @id @default(cuid())
  code             String             @unique
  title            String?
  platform         String             @default("Multimango")
  category         String?
  lifecycle        ProjectLifecycle   @default(LIVE)
  allocationStatus AllocationStatus   @default(ALLOCATED)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  allocations      ProjectAllocation[]
  workItems        WorkItem[]
  flags            ProjectFlag[]
  aiInsights       AiInsight[]
}

model ProjectAllocation {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProjectFlag {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  note      String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation("FlagCreator", fields: [userId], references: [id], onDelete: Cascade)
}

model WorkItem {
  id                String         @id @default(cuid())
  title             String
  userId            String
  projectId         String?
  status            WorkItemStatus @default(PENDING)
  qualityScore      Float?
  reviewComment     String?
  reviewedAt        DateTime?
  reviewedById      String?
  handleTimeMinutes Int?
  completedAt       DateTime?
  dueDate           DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reviewedBy        User?          @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
}

enum ActivityType {
  LEAVE_REQUESTED
  LEAVE_APPROVED
  LEAVE_REJECTED
  TASK_REVIEWED
  PROJECT_FLAGGED
  CHECK_IN
  WORK_COMPLETED
}

model Activity {
  id         String       @id @default(cuid())
  type       ActivityType
  message    String
  actorId    String?
  entityId   String?
  entityType String?
  createdAt  DateTime     @default(now())
  actor      User?        @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model LeaveRequest {
  id        String      @id @default(cuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  reason    String?
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attendance {
  id        String           @id @default(cuid())
  userId    String
  date      DateTime
  status    AttendanceStatus @default(ABSENT)
  checkIn   DateTime?
  checkOut  DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String?
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiInsight {
  id          String   @id @default(cuid())
  type        String   
  title       String
  description String
  score       Float?
  projectId   String?
  createdAt   DateTime @default(now())
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Analytics {
  id            String   @id @default(cuid())
  userId        String
  velocityScore Float
  qualityScore  Float
  tasksCompleted Int
  recordedAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
