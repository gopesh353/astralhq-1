# ── Local dev (no Docker/Postgres) ─────────────────────────────────────────────
# Run once:  npm run setup:local
# Then:      npm run dev   (from repo root)
# Uses SQLite via .env.sqlite — copied automatically by the dev script.

NODE_ENV=development
PORT=3000
APP_NAME=Ethara AI API

# Production / Docker — uncomment and run: npm run docker:up && npm run db:deploy
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/astralhq?schema=public

# Local SQLite (see apps/server/.env.sqlite)
DATABASE_URL="file:../data/dev.db"

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
TOKEN_CLEANUP_INTERVAL_MS=3600000
